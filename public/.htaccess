# Weiterleitung www -> ohne www (offizielle Domain: burchardt-hausverwaltung.de)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_HOST} ^www\.burchardt-hausverwaltung\.de$ [NC]
  RewriteRule ^(.*)$ https://burchardt-hausverwaltung.de/$1 [R=301,L]
</IfModule>

# Sicherheits-Header (Apache/LiteSpeed – Hostinger unterstützt mod_headers)
<IfModule mod_headers.c>
  # Verhindert MIME-Type-Sniffing
  Header always set X-Content-Type-Options "nosniff"
  # Referrer nur sparsam mitsenden
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # Nicht benötigte Browser-Features deaktivieren
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=()"
  # HTTPS erzwingen (bewusst OHNE preload – erst nach stabilem Betrieb erweitern)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  # Content-Security-Policy: nur eigene Assets. Skripte ausschliesslich 'self'
  # (kein ausfuehrbares Inline-JS mehr), Inline-Styles (style-Attribute/<style>)
  # erlaubt, Formular-Ziel Microsoft Forms, kein Einbetten in fremde Frames.
  Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; base-uri 'self'; form-action https://forms.cloud.microsoft; frame-ancestors 'none'; object-src 'none'"
</IfModule>
